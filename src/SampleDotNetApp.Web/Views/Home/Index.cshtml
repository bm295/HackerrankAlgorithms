@model SampleDotNetApp.Web.Models.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h1 class="display-5">SampleDotNetApp</h1>
        <p class="lead">ASP.NET Core MVC app configured for Kestrel-based local runs.</p>

        <div class="card mb-3">
            <div class="card-header">Environment</div>
            <div class="card-body">
                <p class="mb-1"><strong>Current environment:</strong> @Model.Environment</p>
                <p class="mb-1"><strong>App version:</strong> @Model.Version</p>
                <p class="mb-0"><strong>Server time:</strong> @Model.ServerTime.ToString("O")</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Health check</div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li><strong>Status:</strong> @Model.Health?.Status</li>
                    <li><strong>Message:</strong> @Model.HealthSummary</li>
                    <li><strong>Health timestamp (UTC):</strong> @Model.Health?.Timestamp.ToString("O")</li>
                    <li><strong>Environment:</strong> @Model.Health?.Environment</li>
                    <li><strong>Version:</strong> @Model.Health?.Version</li>
                </ul>
            </div>
        </div>
    </div>
</div>
